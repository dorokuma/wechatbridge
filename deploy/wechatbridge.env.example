# WeChatBridge environment configuration
# Copy this file to .env or set variables via systemd EnvironmentFile.
# Uncomment and adjust values for your deployment. Defaults are shown.

# --- iLink (WeChat bot API) ---
# Base URL for the iLink API.
# ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# agy CLI binary path. If empty or "agy", assumes in PATH.
# AGY_BIN_PATH=agy

# --- Storage paths ---
# Per-user session workspace directory.
# WECHATBRIDGE_SESSION_DIR=/var/lib/wechatbridge/sessions

# Bot token persistence file. Default: <repo_root>/.ilink_state.json
# WECHATBRIDGE_STATE_FILE=

# QR code image save path (for login).
# WECHATBRIDGE_QRCODE_PATH=

# QR code URL file path (for external access).
# WECHATBRIDGE_QRCODE_URL_FILE=

# --- Timeouts ---
# agy execution timeout (seconds).
# AGY_TIMEOUT=180

# QR code polling timeout (seconds).
# QRCODE_POLL_TIMEOUT=180

# QR code poll interval (seconds).
# QRCODE_POLL_INTERVAL=1.5

# CDN upload timeout (seconds).
# CDN_UPLOAD_TIMEOUT=120

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO

# --- Media ---
# iLink CDN base URL for image download.
# WECHATBRIDGE_CDN_BASE=https://novac2c.cdn.weixin.qq.com/c2c

# agy scratch directory — where agy writes generated files.
# AGY_SCRATCH_DIR=~/.gemini/antigravity-cli/scratch

# Scratch file retention days (TTL cleanup).
# AGY_SCRATCH_RETENTION_DAYS=7

# Maximum outbound file size in bytes. 100 MB default (Tencent OpenClaw SDK limit).
# WECHATBRIDGE_MAX_OUTBOUND_BYTES=104857600

# --- Access control ---
# Comma-separated WeChat user IDs allowed to use the bridge. Empty = allow all.
# WECHATBRIDGE_ALLOWED_SENDERS=

# Enable /mcp slash command (agy MCP tool guidance).
# WECHATBRIDGE_ENABLE_MCP=true

# Enable /agent slash command (subagent invocation).
# WECHATBRIDGE_ENABLE_SUBAGENT=true

# --- Dangerous prompt confirmation ---
# Comma-separated custom dangerous keywords. Empty = use built-in list.
# WECHATBRIDGE_CONFIRM_KEYWORDS=

# Pending confirmation TTL (seconds).
# WECHATBRIDGE_PENDING_TTL=300

# Confirmation keyword user must reply to execute a dangerous prompt.
# WECHATBRIDGE_CONFIRM_TOKEN=y
